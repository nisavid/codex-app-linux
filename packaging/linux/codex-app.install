__UPDATER_SERVICE_PREAMBLE__

post_install() {
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database /usr/share/applications >/dev/null 2>&1 || true
    fi
__UPDATER_POST_INSTALL__
}

post_upgrade() {
    post_install
}

pre_remove() {
__UPDATER_PRE_REMOVE__
}

post_remove() {
__UPDATER_POST_REMOVE__
}
