#!/bin/sh
set -eu

SERVICE_HELPER="/opt/codex-app/update-builder/packaging/linux/codex-app-updater-user-service.sh"
if [ -f "$SERVICE_HELPER" ]; then
    # shellcheck source=/opt/codex-app/update-builder/packaging/linux/codex-app-updater-user-service.sh
    . "$SERVICE_HELPER"
    codex_ensure_user_service_running || true
fi

exit 0
