[Desktop Entry]
Name=Codex
Comment=Run Codex on Linux
Exec=env BAMF_DESKTOP_FILE_HINT=/usr/share/applications/codex-app.desktop CHROME_DESKTOP=codex-app.desktop /usr/bin/codex-app
Icon=codex-app
Terminal=false
Type=Application
Categories=Development;
StartupNotify=true
StartupWMClass=codex-app
X-GNOME-WMClass=codex-app
