[Desktop Entry]
Name=Codex App
Comment=Run Codex App on Linux
# Workaround: desktop launches can inherit malformed Lmod BASH_FUNC_* exports
# left by Codex CLI shell snapshot replay. Bash imports those variables before
# the launcher starts and prints warnings. The real fix belongs in Codex CLI
# capture/replay: scrub stale BASH_FUNC_* values or recreate exported Bash
# functions consistently, then remove these targeted unsets.
Exec=env -u BASH_FUNC_ml%%%% -u BASH_FUNC_module%%%% BAMF_DESKTOP_FILE_HINT=/usr/share/applications/codex-app.desktop CHROME_DESKTOP=codex-app.desktop /usr/bin/codex-app %u
Icon=codex-app
Terminal=false
Type=Application
Categories=Development;
MimeType=x-scheme-handler/codex;x-scheme-handler/codex-browser-sidebar;
StartupNotify=true
StartupWMClass=codex-app
X-GNOME-WMClass=codex-app
Actions=new-window;CheckForUpdates;InstallReadyUpdate;

[Desktop Action new-window]
Name=New Window
Exec=env -u BASH_FUNC_ml%%%% -u BASH_FUNC_module%%%% BAMF_DESKTOP_FILE_HINT=/usr/share/applications/codex-app.desktop CHROME_DESKTOP=codex-app.desktop CODEX_MULTI_LAUNCH=1 /usr/bin/codex-app --new-instance

[Desktop Action CheckForUpdates]
Name=Check for Updates
Exec=/usr/bin/codex-app-updater check-now

[Desktop Action InstallReadyUpdate]
Name=Install Ready Update
Exec=/usr/bin/codex-app-updater install-ready
